    {
      "name": "duplicate JSON key",
      "wireText": "{\"type\":\"heartbeat.ping\",\"type\":\"heartbeat.pong\",\"requestId\":\"duplicate-key\",\"protocolVersion\":\"1.0\",\"payload\":{\"sentAtMs\":1}}",
      "expectedError": "DUPLICATE_JSON_KEY"
